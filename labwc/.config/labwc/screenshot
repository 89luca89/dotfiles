#!/bin/sh
# screenshot [screen|region|window]
# Saves to ~/Pictures/screenshots, copies to clipboard, and notifies.
# NOTE: labwc has no IPC for the focused window's geometry, so "window" is a
# region select (drag the window). Whole-screen and region are exact.
mode=${1:-screen}
dir="${XDG_PICTURES_DIR:-$HOME/Pictures}/screenshots"
mkdir -p "$dir"
f="$dir/$(date +%Y%m%d-%H%M%S).png"

case "$mode" in
  screen) grim "$f" ;;
  region|window)
    geo=$(slurp) || exit 0          # cancelled -> quietly stop
    [ -n "$geo" ] || exit 0
    grim -g "$geo" "$f" ;;
  *) echo "usage: screenshot [screen|region|window]" >&2; exit 1 ;;
esac

[ -f "$f" ] || exit 0
wl-copy < "$f"
notify-send "Screenshot" "Copied to clipboard + $f" -i "$f"
# To preview/annotate instead of (or before) saving, pipe through swappy:
#   grim -g "$geo" - | swappy -f -
