#!/bin/sh

. /etc/os-release
if grep -q localhost /etc/hostname; then
	printf "select new hostname: "
	read -r hostname
	sudo hostnamectl set-hostname "$hostname"
fi

set -x
set -o errexit
set -o nounset

echo "
# Zram setup
vm.dirty_background_ratio = 10
vm.dirty_expire_centisecs = 6000
vm.dirty_ratio = 20
vm.dirty_writeback_centisecs = 1500
vm.laptop_mode = 5
vm.min_free_kbytes=67584
vm.page-cluster = 0
vm.swappiness = 180
vm.watermark_boost_factor = 0
vm.watermark_scale_factor = 1" | sudo tee /etc/sysctl.d/99-sysctl-custom.conf > /dev/null
sudo sysctl --system --quiet || :

echo "[zram0]
zram-size = ram" | sudo tee /etc/systemd/zram-generator.conf > /dev/null

echo '#
ACTION=="add", SUBSYSTEM=="acpi", DRIVERS=="button", ATTRS{hid}=="PNP0C0D", ATTR{power/wakeup}="disabled"
ACTION=="add", SUBSYSTEM=="serio", DRIVERS=="atkbd", ATTR{power/wakeup}="disabled"
ACTION=="add|change", SUBSYSTEM=="acpi", ATTR{power/control}="auto"
ACTION=="add|change", SUBSYSTEM=="ahci", ATTR{power/control}="auto"
ACTION=="add|change", SUBSYSTEM=="block", ATTR{power/control}="auto"
ACTION=="add|change", SUBSYSTEM=="i2c", ATTR{power/control}="auto"
ACTION=="add|change", SUBSYSTEM=="thunderbolt", ATTR{power/control}="auto"
ACTION=="add|change", SUBSYSTEM=="net", KERNEL=="enp*", RUN+="/usr/sbin/ethtool -s %k wol d"
ACTION=="add|change", SUBSYSTEM=="net", KERNEL=="wlp*", RUN+="/usr/sbin/iw dev %k set power_save on"
ACTION=="add|change", SUBSYSTEM=="pci", ATTR{power/control}="auto"
ACTION=="add|change", SUBSYSTEM=="scsi", ATTR{power/control}="auto"
ACTION=="add|change", SUBSYSTEM=="pci", ATTR{power/wakeup}="disabled"
ACTION=="add|change", SUBSYSTEM=="usb", ATTR{power/wakeup}="disabled"
ACTION=="add|change", SUBSYSTEM=="thunderbolt", ATTR{power/wakeup}="disabled"
ACTION=="add|change", SUBSYSTEM=="scsi_host", KERNEL=="host*", ATTR{link_power_management_policy}="min_power"
ACTION=="add|change", SUBSYSTEM=="usb", ATTR{power/autosuspend}="1"
ACTION=="add|change", SUBSYSTEM=="usb", ATTR{power/autosuspend_delay_ms}="500"
ACTION=="add|change", SUBSYSTEM=="workqueue", ATTR{power/control}="auto"
ACTION=="add|change", KERNEL=="sd[a-z][0-9]", RUN+="/usr/sbin/blockdev --setra 4096 /dev/%k"
ACTION=="add|change", KERNEL=="nvme[0-9]n[0-9]p[0-9]", RUN+="/usr/sbin/blockdev --setra 4096 /dev/%k"
ACTION=="add|change", KERNEL=="dm-[0-9]", RUN+="/usr/sbin/blockdev --setra 4096 /dev/%k"
' | sudo tee /etc/udev/rules.d/powersave.rules > /dev/null
sudo udevadm control --reload
sudo udevadm trigger

echo "[connection]
wifi.powersave = 3" | sudo tee /etc/NetworkManager/conf.d/wifi-powersave.conf

echo "[Unit]
Description=Run udev trigger after wake
After=suspend.target hibernate.target hybrid-sleep.target suspend-then-hibernate.target
[Service]
ExecStart=/usr/bin/udevadm trigger
[Install]
WantedBy=suspend.target hibernate.target hybrid-sleep.target suspend-then-hibernate.target" | sudo tee /etc/systemd/system/udev-suspend.service
sudo systemctl enable --now udev-suspend.service

if [ -e /etc/lvm/lvm.conf ]; then
	sudo sed -i 's|# issue_discards = 0|issue_discards = 1|g' /etc/lvm/lvm.conf
fi

LUKS_DEVICES="$(lsblk --list --fs | grep nvme | grep LUKS | cut -d' ' -f1)"
if [ -n "$LUKS_DEVICES" ]; then
	if [ -e /etc/crypttab ]; then
		if ! sudo grep discard /etc/crypttab; then
			for disk in $(sudo grep -v '^#' /etc/crypttab | cut -d' ' -f1); do
				sudo cryptsetup --allow-discards --persistent refresh "$disk"
			done
		fi
		sudo sed -i 's|none $|none luks,x-initrd.attach,discard,tpm2-device=auto|g' /etc/crypttab
		sudo sed -i 's|none luks$|none luks,x-initrd.attach,discard,tpm2-device=auto|g' /etc/crypttab
		sudo sed -i 's|none discard$|none luks,x-initrd.attach,discard,tpm2-device=auto|g' /etc/crypttab
		sudo sed -i 's|x-initrd.attach$|luks,x-initrd.attach,discard,tpm2-device=auto|g' /etc/crypttab
	fi
	sudo systemctl enable fstrim.timer
	sudo fstrim -va
fi

echo "install adfs /bin/false
install af_802154 /bin/false
install affs /bin/false
install afs /bin/false
install algif_aead /bin/false
install appletalk /bin/false
install atm /bin/false
install ax25 /bin/false
install befs /bin/false
install can /bin/false
install cdrom /bin/false
install ceph /bin/false
install cifs /bin/false
install coda /bin/false
install cramfs /bin/false
install cyber2000fb /bin/false
install cyblafb /bin/false
install dccp /bin/false
install decnet /bin/false
install dv1394 /bin/false
install econet /bin/false
install esp4 /bin/false
install esp6 /bin/false
install f2fs /bin/false
install firewire-core /bin/false
install firewire-net /bin/false
install firewire-ohci /bin/false
install firewire-sbp2 /bin/false
install firewire_core /bin/false
install firewire_ohci /bin/false
install firewire_sbp2 /bin/false
install floppy /bin/false
install freevxfs /bin/false
install gfs2 /bin/false
install gnss /bin/false
install gnss-mtk /bin/false
install gnss-serial /bin/false
install gnss-sirf /bin/false
install gnss-ubx /bin/false
install gnss-usb /bin/false
install gx1fb /bin/false
install hfs /bin/false
install hfsplus /bin/false
install hgafb /bin/false
install ipx /bin/false
install jffs2 /bin/false
install jfs /bin/false
install kafs /bin/false
install ksmbd /bin/false
install kyrofb /bin/false
install lxfb /bin/false
install matroxfb_base /bin/false
install minix /bin/false
install n-hdlc /bin/false
install neofb /bin/false
install netrom /bin/false
install nfsd /bin/false
install nilfs2 /bin/false
install nvidiafb /bin/false
install ocfs2 /bin/false
install ohci1394 /bin/false
install omfs /bin/false
install orangefs /bin/false
install p8022 /bin/false
install p8023 /bin/false
install pm2fb /bin/false
install psnap /bin/false
install qnx4 /bin/false
install qnx6 /bin/false
install raw1394 /bin/false
install rds /bin/false
install reiserfs /bin/false
install romfs /bin/false
install rose /bin/false
install rxrpc /bin/false
install s1d13xxxfb /bin/false
install sbp2 /bin/false
install sctp /bin/false
install sisfb /bin/false
install sr_mod /bin/false
install sysv /bin/false
install tdfxfb /bin/false
install tipc /bin/false
install ubifs /bin/false
install udf /bin/false
install udlfb /bin/false
install ufs /bin/false
install vesafb /bin/false
install vfb /bin/false
install video1394 /bin/false
install vivid /bin/false
install vt8623fb /bin/false
install x25 /bin/false
install zonefs /bin/false" | sudo tee /etc/modprobe.d/hardening.conf > /dev/null

echo "options amdgpu dcfeaturemask=0x38B ppfeaturemask=0xffffbfff sg_display=0 aspm=1
options i915 enable_dc=4 enable_dmc_wl=1 enable_dpcd_backlight=1 enable_fbc=1 enable_flipq=1 enable_panel_replay=1 enable_psr2_sel_fetch=1 enable_psr=1
options xe enable_dc=4 enable_dmc_wl=1 enable_dpcd_backlight=1 enable_fbc=1 enable_flipq=1 enable_panel_replay=1 enable_psr2_sel_fetch=1 enable_psr=1
options ath9k ps_enable=1
options btusb enable_autosuspend=y
options iwlmvm power_scheme=3
options iwlwifi power_save=Y power_level=5
options mt7921e disable_aspm=0
options mt7925e disable_aspm=0
options rtw88 disable_lps_deep=N
options rtw89_core disable_ps_mode=N
options rtw89_pci disable_aspm_l1=0 disable_aspm_l1ss=0 disable_clkreq=N
options snd_ac97_codec power_save=1
options snd_hda_intel power_save=1 power_save_controller=y" | sudo tee /etc/modprobe.d/powersave.conf > /dev/null

KERNEL_CMDLINE=""
KERNEL_CMDLINE="$KERNEL_CMDLINE efi=disable_early_pci_dma"
KERNEL_CMDLINE="$KERNEL_CMDLINE iommu.strict=1"
KERNEL_CMDLINE="$KERNEL_CMDLINE rd.emergency=reboot"
KERNEL_CMDLINE="$KERNEL_CMDLINE rd.shell=0"
KERNEL_CMDLINE="$KERNEL_CMDLINE preempt=lazy"
KERNEL_CMDLINE="$KERNEL_CMDLINE amd_pstate=active"
KERNEL_CMDLINE="$KERNEL_CMDLINE intel_pstate=active"
KERNEL_CMDLINE="$KERNEL_CMDLINE drm.vblankoffdelay=1"
KERNEL_CMDLINE="$KERNEL_CMDLINE loglevel=0"
KERNEL_CMDLINE="$KERNEL_CMDLINE nmi_watchdog=0"
KERNEL_CMDLINE="$KERNEL_CMDLINE nowatchdog"
KERNEL_CMDLINE="$KERNEL_CMDLINE nvme_core.default_ps_max_latency_us=5000000"
KERNEL_CMDLINE="$KERNEL_CMDLINE pcie_aspm.policy=powersupersave"
KERNEL_CMDLINE="$KERNEL_CMDLINE pcie_aspm=force"
KERNEL_CMDLINE="$KERNEL_CMDLINE rtc_cmos.use_acpi_alarm=1"
KERNEL_CMDLINE="$KERNEL_CMDLINE usbcore.autosuspend=1"
KERNEL_CMDLINE="$KERNEL_CMDLINE workqueue.power_efficient=Y"
KERNEL_CMDLINE="$KERNEL_CMDLINE lru_gen.enabled=7"

systemd_user_services="
	evolution-addressbook-factory.service
	evolution-calendar-factory.service
	evolution-source-registry.service
	evolution-user-prompter.service
	gvfs-goa-volume-monitor.service
	localsearch-3.service
	localsearch-control-3.service
	localsearch-writeback-3.service
	spice-vdagent.service
	tracker-extract-3.service
	tracker-miner-fs-3.service
	tracker-miner-fs-control-3.service
	tracker-miner-rss-3.service
	tracker-writeback-3.service
	tracker-xdg-portal-3.service
"
for systemd_user_service in ${systemd_user_services}; do
	systemctl --user disable --now "${systemd_user_service}" 2> /dev/null || :
	systemctl --user mask --now "${systemd_user_service}" 2> /dev/null || :
done

systemd_system_services="
	NetworkManager-wait-online
	abrt-journal-core
	abrt-oops
	abrt-xorg
	abrtd
	geoclue
	motd-news.timer
	nfs-idmapd
	nfs-mountd
	nfsdcld
	packagekit
	rpc-gssd
	rpc-statd
	rpc-statd-notify
	rpcbind
"
for service in $systemd_system_services; do
	sudo systemctl disable --now "$service" || :
	sudo systemctl mask "$service" || :
done

###############  Bootup
# grub case
if [ -e /etc/default/grub ] && ! grep -q "$KERNEL_CMDLINE" /etc/default/grub; then
	sudo sed -i 's|quiet"|quiet splash"|g' /etc/default/grub
	sudo sed -i "s|GRUB_CMDLINE_LINUX=\".*\"|GRUB_CMDLINE_LINUX=\"quiet splash $KERNEL_CMDLINE\"|g" /etc/default/grub
fi

# systemd-boot case
if ! grep -q "$KERNEL_CMDLINE" /etc/kernel/cmdline; then
	sudo sed -i "s|quiet|quiet $KERNEL_CMDLINE|g" /etc/kernel/cmdline
fi

sudo kernel-install -v add-all

# Distro specific stuff
"$(dirname "${0}")/setup-${ID}"

# TPM
if [ ! -e "/etc/kernel/pcr-private-key.pem" ]; then
	bits=2048
	if sudo tpm2_testparms rsa4096 2> /dev/null; then
		bits=4096
	fi
	sudo openssl genrsa -out /etc/kernel/pcr-private-key.pem "$bits"
	sudo openssl rsa -pubout -in /etc/kernel/pcr-private-key.pem -out /etc/kernel/pcr-public-key.pem
	sudo chmod 600 /etc/kernel/pcr-private-key.pem

	echo "[UKI]
PCRBanks=sha256

[PCRSignature:initrd]
PCRPrivateKey=/etc/kernel/pcr-private-key.pem
PCRPublicKey=/etc/kernel/pcr-public-key.pem
Phases=enter-initrd enter-initrd:leave-initrd:sysinit:ready" | sudo tee /etc/kernel/uki.conf > /dev/null
	sudo kernel-install -v add-all
fi

# Recoverky UKI
if ! sudo ls /boot/efi/EFI/Linux/recovery.efi; then
	kver=$(uname -r)
	sudo dracut --force --kver "$kver" /tmp/recovery-initrd.img
	sudo ukify build \
		--linux="/usr/lib/modules/$kver/vmlinuz" \
		--initrd=/tmp/recovery-initrd.img \
		--cmdline="$(cat /etc/kernel/cmdline) rd.break=pre-mount" \
		--uname="$kver" \
		--output=/boot/efi/EFI/Linux/recovery.efi
	sudo sbctl sign -s /boot/efi/EFI/Linux/recovery.efi
fi

for i in /dev/*; do
	if sudo cryptsetup luksUUID "$i" 2> /dev/null; then
		sudo systemd-cryptenroll \
			--tpm2-device=auto \
			--wipe-slot=tpm2 \
			--tpm2-pcrs="0+1+2+3+7" \
			--tpm2-public-key-pcrs=11 --tpm2-public-key=/etc/kernel/pcr-public-key.pem \
			"$i"
	fi
done
